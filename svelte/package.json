{
	"name": "treeimprovementbase",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "npm run setup && vite dev",
		"build": "npm run setup && vite build",
		"build-watch": "npm run setup && vite build --watch",
		"preview": "npm run setup && vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"setup": "bash -c 'if [[ ! -f .env ]]; then cp .env.template .env; fi'"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^0.577.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"formsnap": "^2.0.1",
		"svelte": "^5.53.13",
		"svelte-check": "^4.4.5",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@tanstack/table-core": "^8.21.3",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	}
}
